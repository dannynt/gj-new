import { useState, useEffect } from 'react'
import {
  Box,
  Text,
  VStack,
  HStack,
  Button,
  Image,
  Heading,
  Link,
  Flex,
  keyframes,
} from '@chakra-ui/react'
import { motion, AnimatePresence } from 'framer-motion'
import { FaGamepad } from 'react-icons/fa'

const MotionBox = motion(Box)
const MotionText = motion(Text)

// Glow pulse animation
const glowPulse = keyframes`
  0%, 100% { box-shadow: 0 0 10px rgba(169, 200, 230, 0.15); }
  50% { box-shadow: 0 0 15px rgba(169, 200, 230, 0.25); }
`

// Google Forms URL - replace with your actual form URL
const GOOGLE_FORM_URL = 'https://forms.gle/YOUR_FORM_ID'

// Target date: April 17, 2026 at 19:30
const TARGET_DATE = new Date('2026-04-17T19:30:00')

// Animated countdown digit
const CountdownDigit = ({ value }: { value: string }) => (
  <AnimatePresence mode="popLayout">
    <MotionText
      key={value}
      initial={{ y: -20, opacity: 0, scale: 0.8 }}
      animate={{ y: 0, opacity: 1, scale: 1 }}
      exit={{ y: 20, opacity: 0, scale: 0.8 }}
      transition={{ duration: 0.25, ease: 'easeOut' }}
      fontSize={{ base: '3xl', md: '5xl' }}
      fontWeight="bold"
      color="white"
      fontFamily="'Fredoka One', cursive"
      textShadow="0 2px 20px rgba(169, 200, 230, 0.6)"
      lineHeight={1}
    >
      {value}
    </MotionText>
  </AnimatePresence>
)

// Countdown unit with flip animation
const CountdownUnit = ({ value, label, color = '#A9C8E6' }: { value: number; label: string; color?: string }) => {
  const displayValue = String(value).padStart(2, '0')
  
  return (
    <VStack spacing={2}>
      <Box
        bg="rgba(10, 10, 10, 0.95)"
        border="3px solid"
        borderColor={color}
        borderRadius="lg"
        px={{ base: 4, md: 6 }}
        py={{ base: 3, md: 4 }}
        minW={{ base: '65px', md: '90px' }}
        position="relative"
        overflow="hidden"
        _before={{
          content: '""',
          position: 'absolute',
          top: 0,
          left: 0,
          right: 0,
          height: '50%',
          bg: 'linear-gradient(180deg, rgba(255,255,255,0.05) 0%, transparent 100%)',
          borderRadius: 'lg lg 0 0',
        }}
        _after={{
          content: '""',
          position: 'absolute',
          top: '50%',
          left: '10%',
          right: '10%',
          height: '1px',
          bg: `${color}30`,
        }}
      >
        <HStack spacing={0} justify="center">
          <CountdownDigit value={displayValue[0]} />
          <CountdownDigit value={displayValue[1]} />
        </HStack>
      </Box>
      <Text 
        fontSize={{ base: '2xs', md: 'xs' }} 
        color={color}
        fontFamily="'Fredoka One', cursive"
        letterSpacing="widest"
        textTransform="uppercase"
      >
        {label}
      </Text>
    </VStack>
  )
}

// Colon separator with pulse
const ColonSeparator = () => (
  <MotionBox
    animate={{ opacity: [1, 0.3, 1] }}
    transition={{ duration: 1, repeat: Infinity }}
    pb={{ base: 6, md: 8 }}
  >
    <Text 
      fontSize={{ base: '2xl', md: '4xl' }} 
      color="#A9C8E6" 
      fontFamily="'Fredoka One', cursive"
    >
      :
    </Text>
  </MotionBox>
)

export default function Hero() {
  const [timeLeft, setTimeLeft] = useState({
    days: 0,
    hours: 0,
    minutes: 0,
    seconds: 0,
  })

  useEffect(() => {
    const calculateTimeLeft = () => {
      const now = new Date()
      const difference = TARGET_DATE.getTime() - now.getTime()

      if (difference > 0) {
        setTimeLeft({
          days: Math.floor(difference / (1000 * 60 * 60 * 24)),
          hours: Math.floor((difference / (1000 * 60 * 60)) % 24),
          minutes: Math.floor((difference / 1000 / 60) % 60),
          seconds: Math.floor((difference / 1000) % 60),
        })
      }
    }

    calculateTimeLeft()
    const timer = setInterval(calculateTimeLeft, 1000)
    return () => clearInterval(timer)
  }, [])

  return (
    <MotionBox
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      transition={{ duration: 0.8 }}
      w="full"
      textAlign="center"
      py={{ base: 4, md: 6 }}
      position="relative"
      zIndex={1}
    >
      <VStack spacing={{ base: 6, md: 8 }}>
        {/* Tagline with stagger animation */}
        <VStack spacing={1}>
          <MotionBox
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, delay: 0.2 }}
          >
            <Text
              fontSize={{ base: 'md', md: 'lg' }}
              color="white"
              fontFamily="'Fredoka One', cursive"
              textShadow="2px 2px 4px rgba(0,0,0,0.8)"
              letterSpacing="wide"
            >
              TULE JA TEE OMA
            </Text>
          </MotionBox>
          <MotionBox
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, delay: 0.4 }}
          >
            <Heading
              fontSize={{ base: 'xl', md: '2xl' }}
              color="white"
              fontFamily="'Fredoka One', cursive"
              textShadow="3px 3px 6px rgba(0,0,0,0.8)"
              bgGradient="linear(to-r, white, #A9C8E6)"
              bgClip="text"
            >
              ESIMENE MÄNG!
            </Heading>
          </MotionBox>
        </VStack>

        {/* Logo with hover effect */}
        <MotionBox
          initial={{ opacity: 0, scale: 0.8 }}
          animate={{ opacity: 1, scale: 1 }}
          transition={{ duration: 0.6, delay: 0.5 }}
          whileHover={{ scale: 1.02 }}
        >
          <Image 
            src="/img/logo.png" 
            alt="TÜ Mängu-Jamm" 
            w={{ base: '200px', md: '280px' }}
            h="auto"
            filter="drop-shadow(0 4px 30px rgba(169, 200, 230, 0.3))"
          />
        </MotionBox>

        {/* Date & Location Box */}
        <MotionBox
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, delay: 0.7 }}
        >
          <Box
            bg="rgba(10, 10, 10, 0.95)"
            border="3px solid"
            borderColor="#A9C8E6"
            borderRadius="xl"
            px={{ base: 8, md: 12 }}
            py={{ base: 4, md: 5 }}
            animation={`${glowPulse} 3s ease-in-out infinite`}
          >
            <VStack spacing={1}>
              <Heading
                fontSize={{ base: 'xl', md: '2xl' }}
                color="white"
                fontFamily="'Fredoka One', cursive"
                letterSpacing="wider"
              >
                17 - 19 APRILL
              </Heading>
              <Text
                fontSize={{ base: 'sm', md: 'md' }}
                color="white"
                fontWeight="bold"
              >
                DELTA ÕPPEHOONES
              </Text>
              <Text fontSize="xs" color="#A9C8E6" fontStyle="italic">
                või võrgupõhiselt
              </Text>
            </VStack>
          </Box>
        </MotionBox>

        {/* Countdown Timer */}
        <MotionBox
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, delay: 0.9 }}
        >
          <VStack spacing={3}>
            <Text 
              fontSize={{ base: 'xs', md: 'sm' }} 
              color="#8B8B8B"
              fontFamily="'Fredoka One', cursive"
              letterSpacing="widest"
            >
              ALGUSENI JÄÄNUD
            </Text>
            <Flex 
              gap={{ base: 1, md: 3 }} 
              align="flex-start"
              justify="center"
              flexWrap="wrap"
            >
              <CountdownUnit value={timeLeft.days} label="päeva" color="#A9C8E6" />
              <ColonSeparator />
              <CountdownUnit value={timeLeft.hours} label="tundi" color="#A9C8E6" />
              <ColonSeparator />
              <CountdownUnit value={timeLeft.minutes} label="minutit" color="#A9C8E6" />
              <ColonSeparator />
              <CountdownUnit value={timeLeft.seconds} label="sekundit" color="#A9C8E6" />
            </Flex>
          </VStack>
        </MotionBox>

        {/* CTA Button */}
        <MotionBox
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5, delay: 1.1 }}
        >
          <Button
            as={Link}
            href={GOOGLE_FORM_URL}
            isExternal
            size="lg"
            bg="#0A0A0A"
            color="#DB551C"
            fontFamily="'Fredoka One', cursive"
            fontSize={{ base: 'sm', md: 'md' }}
            px={{ base: 5, md: 8 }}
            py={6}
            border="3px solid #DB551C"
            borderRadius="xl"
            _hover={{
              bg: '#DB551C',
              color: 'white',
              textDecoration: 'none',
              transform: 'translateY(-3px)',
              boxShadow: '0 4px 15px rgba(219, 85, 28, 0.25)',
            }}
            _active={{ transform: 'translateY(-1px)' }}
            transition="all 0.2s"
            leftIcon={<FaGamepad />}
          >
            REGISTREERU
          </Button>
        </MotionBox>
      </VStack>
    </MotionBox>
  )
}
